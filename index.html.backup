  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Abdisamad Yusuf",
    "url": "https://abdisamadjoe.com/",
    "image": "https://abdisamadjoe.com/hero.png",
    "sameAs": [
      "https://linkedin.com/in/abdisamadjoe",
      "https://x.com/abdisamadjoe",
      "https://medium.com/@abdisamadjoe"
    ],
    "jobTitle": "Cybersecurity Professional",
    "worksFor": {
      "@type": "Organization",
      "name": "GuardAura"
    }
  }
  </script>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        fontFamily: { inter: ['Inter', 'sans-serif'] },
        extend: {
          colors: {
            navy: '#0f172a',
            mint: '#00ff9d'
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    ::selection { background: #00ff9d; color: #0f172a; }
    @keyframes typing {
      0% { width: 0 }
      40% { width: 100% }
      60% { width: 100% }
      100% { width: 0 }
    }
    @keyframes blink {
      50% { border-color: transparent }
    }
    .typing-demo {
      width: 0;
      animation:
        typing 4s steps(32, end) infinite,
        blink 1s steps(2, start) infinite;
      display: inline-block;
      overflow: hidden;
      white-space: nowrap;
      border-right: .15em solid #00ff9d;
    }
    @keyframes float1 {
      0%, 100% { transform: translateY(0) scale(0.8);}
      50% { transform: translateY(-18px) scale(0.85);}
    }
    @keyframes float2 {
      0%, 100% { transform: translateY(0) scale(0.8);}
      50% { transform: translateY(14px) scale(0.84);}
    }
    @keyframes float3 {
      0%, 100% { transform: translateY(0) scale(0.8);}
      50% { transform: translateY(-10px) scale(0.82);}
    }
    .animate-float1 { animation: float1 4s ease-in-out infinite; }
    .animate-float2 { animation: float2 5s ease-in-out infinite; }
    .animate-float3 { animation: float3 3.5s ease-in-out infinite; }
    .glass-tag {
      background: rgba(15,23,42,0.7);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 0 8px 1px #00ff9d55;
      font-size: 0.8rem;
      padding: 0.25rem 0.75rem;
    }
    @keyframes wave {
      0% { transform: rotate(0deg);}
      10% { transform: rotate(14deg);}
      20% { transform: rotate(-8deg);}
      30% { transform: rotate(14deg);}
      40% { transform: rotate(-4deg);}
      50% { transform: rotate(10deg);}
      60% { transform: rotate(0deg);}
      100% { transform: rotate(0deg);}
    }
    .animate-wave {
      animation: wave 2s infinite;
      display: inline-block;
    }
    .badge-mint:hover {
      background-color: #00ff9d !important;
      color: #0f172a !important;
    }
    @media (max-width: 900px) {
      .hero-headline, .hero-typing { font-size: 1.2rem !important; }
    }
  </style>
</head>
<body class="bg-[#0f172a] text-white min-h-screen flex flex-col relative overflow-x-hidden font-inter">

  <!-- Floating Particles Background -->
  <div class="pointer-events-none fixed inset-0 z-0">
    <svg class="w-full h-full" style="opacity:0.18">
      <circle cx="10%" cy="20%" r="3" fill="#00ff9d">
        <animate attributeName="cy" values="20%;80%;20%" dur="12s" repeatCount="indefinite"/>
      </circle>
      <circle cx="80%" cy="60%" r="2.5" fill="#00ff9d">
        <animate attributeName="cy" values="60%;30%;60%" dur="10s" repeatCount="indefinite"/>
      </circle>
      <circle cx="50%" cy="80%" r="2" fill="#00ff9d">
        <animate attributeName="cy" values="80%;10%;80%" dur="14s" repeatCount="indefinite"/>
      </circle>
      <circle cx="30%" cy="40%" r="2.5" fill="#00ff9d">
        <animate attributeName="cy" values="40%;70%;40%" dur="11s" repeatCount="indefinite"/>
      </circle>
      <circle cx="70%" cy="10%" r="2" fill="#00ff9d">
        <animate attributeName="cy" values="10%;90%;10%" dur="13s" repeatCount="indefinite"/>
      </circle>
    </svg>
  </div>

<!-- Centered Frosted Glass Navbar -->
<nav class="sticky top-0 z-50 w-full bg-white/5 backdrop-blur-md border-b border-white/10 font-inter">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <!-- Logo (always visible) -->
    <a href="#home" class="flex items-center">
      <img src="abdisamadylogo.svg" alt="Abdisamad Logo" class="h-8 w-auto">
    </a>
    <!-- Desktop Menu -->
    <ul class="hidden sm:flex space-x-8 text-sm font-medium">
      <li>
        <a href="#home" class="text-white transition hover:text-[#00ff9d]">Home</a>
      </li>
      <li>
        <a href="#work" class="text-white transition hover:text-[#00ff9d]">Work</a>
      </li>
      <li>
        <a href="https://medium.com/@abdisamadjoe" target="_blank" rel="noopener" class="text-white transition hover:text-[#00ff9d]">Blogs</a>
      </li>
      <li>
        <a href="#contact" class="text-white transition hover:text-[#00ff9d]">Contact</a>
      </li>
    </ul>
    <!-- Hamburger Button (Mobile) -->
    <button id="mobile-menu-btn" class="block sm:hidden text-white focus:outline-none" aria-label="Open Menu">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
  <!-- Mobile Dropdown Menu -->
  <div id="mobile-menu" class="sm:hidden hidden px-6">
    <div class="flex flex-col space-y-4 bg-white/5 backdrop-blur-md mt-2 rounded-lg p-4">
      <a href="#home" class="text-white transition hover:text-[#00ff9d]">Home</a>
      <a href="#work" class="text-white transition hover:text-[#00ff9d]">Work</a>
      <a href="https://medium.com/@abdisamadjoe" target="_blank" rel="noopener" class="text-white transition hover:text-[#00ff9d]">Blogs</a>
      <a href="#contact" class="text-white transition hover:text-[#00ff9d]">Contact</a>
    </div>
  </div>
</nav>
<script>
  // Minimal JS for mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn.addEventListener('click', () => {
    menu.classList.toggle('hidden');
  });
</script>


  <!-- Hero Section -->
<section id="home" class="relative min-h-screen flex items-center justify-center">
  <div class="relative z-10 w-full max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8 px-4 pt-0 pb-24 md:pb-12 mt-0 md:mt-0
">
    <!-- Left: Text Content -->
    <div class="flex-1 flex flex-col items-center md:items-start justify-center text-center md:text-left">
      <h3 class="hero-headline text-[1.56rem] sm:text-2xl md:text-3xl lg:text-4xl font-extrabold text-white mb-2 whitespace-nowrap" style="line-height:1.1;">
        Hi,<span class="inline-block animate-wave origin-[70%_70%]">👋</span> I’m Abdisamad Yusuf
      </h3>
      <h3 class="hero-typing block text-[1.56rem] sm:text-2xl md:text-3xl lg:text-4xl font-bold text-[#00ff9d] font-mono typing-demo mb-2 whitespace-nowrap" style="line-height:1.3;">
        – Cybersecurity Professional
      </h3>
      <p class="mt-2 text-base sm:text-base md:text-lg text-white/90 max-w-xl">
        I help businesses and individuals protect their systems from cyber threats through cloud security solutions and expert cybersecurity training.
      </p>
      <a href="resume.pdf" download
        class="mt-8 inline-flex items-center gap-2 px-7 py-3 rounded-full bg-[#00ff9d] text-black font-semibold text-lg transition-all duration-200 hover:bg-white hover:text-black focus:outline-none group">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m0 0l-6-6m6 6l6-6"/>
        </svg>
        Download Resume
      </a>
    </div>
    <!-- Right: Image & Floating Tags -->
    <div class="flex-1 flex items-center justify-center relative min-w-[220px] min-h-[220px] mt-8 md:mt-0">
      <!-- Hero Image (130% of default) -->
      <div class="relative z-10">
        <img src="hero.png" alt="Abdisamad Yusuf" class="w-[220px] h-[220px] sm:w-[312px] sm:h-[312px] md:w-[384px] md:h-[384px] rounded-2xl object-cover mx-auto">
      </div>
      <!-- Tag 1: Lower part, half outside -->
      <div class="absolute bottom-[-1.5rem] left-6 sm:left-12 animate-float1">
        <div class="flex items-center glass-tag rounded-full">
          <svg class="w-3 h-3 mr-1 text-[#00ff9d]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-[#00ff9d] font-semibold">AWS Certified</span>
        </div>
      </div>
      <!-- Tag 2: Inside left -->
      <div class="absolute top-1/3 -left-4 sm:-left-6 animate-float2">
        <div class="flex items-center glass-tag rounded-full">
          <svg class="w-3 h-3 mr-1 text-[#00ff9d]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-[#00ff9d] font-semibold">TryHackMe Top 1%</span>
        </div>
      </div>
      <!-- Tag 3: Inside right -->
      <div class="absolute top-2/3 right-0 animate-float3">
        <div class="flex items-center glass-tag rounded-full">
          <svg class="w-3 h-3 mr-1 text-[#00ff9d]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-[#00ff9d] font-semibold">CompTIA Certified</span>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- About Me -->
<section id="about" class="bg-[#0f172a] font-inter text-white">
  <div class="max-w-4xl mx-auto px-6 py-20 text-center">
    <h2 class="text-4xl font-bold text-white">About Me</h2>
    <p class="text-base md:text-lg text-white/80 leading-relaxed mt-6">
      I'm Abdisamad Yusuf, an aspiring cybersecurity professional with a Computer Science degree and a strong interest in network security and cloud security. Over the past 3 years, I’ve gained hands-on experience in IT support, information security, and web design.
    </p>
    <p class="text-base md:text-lg text-white/80 leading-relaxed mt-6">
      I hold certifications from Google, ISC2, AWS, and Microsoft, and I’m the founder of two startups: 
      <a href="https://guardaura.com/" target="_blank" rel="noopener" class="underline text-white hover:text-[#00ff9d] transition">GuardAura</a>, which offers cybersecurity services, and 
      <a href="https://www.facebook.com/TheSameelo/" target="_blank" rel="noopener" class="underline text-white hover:text-[#00ff9d] transition">Sameelo</a>, focused on web design and digital solutions.
    </p>
    <p class="text-base md:text-lg text-white/80 leading-relaxed mt-6">
      I spend most of my time sharpening my skills on platforms like 
      <a href="https://tryhackme.com/p/bobst0ne" target="_blank" rel="noopener" class="underline text-white hover:text-[#00ff9d] transition">TryHackMe</a> (Top 1% globally), 
      <a href="https://app.letsdefend.io/user/bobst0ne" target="_blank" rel="noopener" class="underline text-white hover:text-[#00ff9d] transition">LetsDefend</a>, and 
      <a href="https://cyberdefenders.org/p/bobst0ne" target="_blank" rel="noopener" class="underline text-white hover:text-[#00ff9d] transition">CyberDefenders</a>. My mission is simple: to help people and businesses stay safe in today’s connected world.
    </p>
    <p class="text-base md:text-lg text-white/80 leading-relaxed mt-6">
      I'm always open to new roles in cybersecurity or cloud computing, meaningful collaborations, and opportunities where I can grow and make a real impact.
    </p>
  </div>
</section>

  <!-- Featured Projects Section -->
  <section id="work" class="relative z-10 w-full max-w-6xl mx-auto py-10 px-4">
  <div class="flex flex-col items-center mb-14">
    <h2 class="text-3xl md:text-4xl font-extrabold text-center mb-2">Featured Projects</h2>
    <p class="text-base md:text-lg text-white/80 text-center max-w-2xl">
      I’ve built several home lab projects while learning cybersecurity. Check out some of my favorite ones below.
    </p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center">
    <!-- Card 1 -->
    <div class="bg-[#0f172a]/60 border border-white/50 backdrop-blur-lg rounded-2xl shadow-lg p-8 w-full max-w-sm flex flex-col items-center transition-transform duration-200 hover:shadow-2xl hover:scale-105">
      <img src="activedirectory.png" alt="Active Directory Lab Setup" class="w-full h-48 object-cover rounded-xl mb-4">
      <h3 class="text-lg font-bold text-white text-center mb-2">Active Directory Lab Setup</h3>
      <p class="text-gray-300 text-sm text-center mb-3">
        Configured a home lab with Active Directory using Oracle VirtualBox, enabling user management and administration through PowerShell.
      </p>
      <div class="flex flex-wrap justify-center gap-2 mb-4">
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">Active Directory</span>
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">Identity Management (IAM)</span>
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">PowerShell</span>
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">Virtual Machine</span>
      </div>
      <a href="https://github.com/abdisamadjoe/AD-PS-User-Management" target="_blank"
         class="inline-flex items-center gap-2 px-4 py-2 bg-mint text-black font-semibold rounded-full transition-colors duration-200 hover:bg-white hover:text-black focus:outline-none">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.339-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.987 1.029-2.686-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.1 2.65.64.699 1.028 1.593 1.028 2.686 0 3.847-2.338 4.695-4.566 4.944.36.31.68.921.68 1.857 0 1.34-.012 2.422-.012 2.753 0 .267.18.578.688.48C19.138 20.203 22 16.447 22 12.021 22 6.484 17.523 2 12 2z"/>
        </svg>
        GitHub
      </a>
    </div>

 <!-- Card 2 -->
    <div class="bg-[#0f172a]/60 border border-white/50 backdrop-blur-lg rounded-2xl shadow-lg p-8 w-full max-w-sm flex flex-col items-center transition-transform duration-200 hover:shadow-2xl hover:scale-105">
      <a href="https://youtu.be/MEgc0qQ3yKE?si=z4Ktw_DZj_psexyA" target="_blank" class="block w-full mb-4 relative group">
        <img src="aws-login.png" alt="AWS Login Alert System" class="w-full h-48 object-cover rounded-xl">
        <span class="absolute inset-0 flex items-center justify-center">
          <svg class="w-16 h-16 text-white/90 group-hover:text-[#00ff9d] transition" fill="currentColor" viewBox="0 0 64 64">
            <circle cx="32" cy="32" r="32" fill="rgba(0,0,0,0.45)"/>
            <polygon points="26,20 48,32 26,44" fill="#fff"/>
          </svg>
        </span>
      </a>
      <h3 class="text-lg font-bold text-white text-center mb-2">AWS Login Alert System with CloudTrail, EventBridge, and SNS</h3>
      <p class="text-gray-300 text-sm text-center mb-3">
        Built a real-time AWS login alert system that emails you whenever the root or IAM user logs in, using CloudTrail, EventBridge, and SNS.
      </p>
      <div class="flex flex-wrap justify-center gap-2 mb-4">
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">CloudTrail</span>
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">EventBridge</span>
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">SNS (Simple Notification Service)</span>
        <span class="inline-block bg-slate-800 text-gray-100 px-3 py-1 rounded-full text-sm font-medium transition-transform duration-200 badge-mint hover:scale-105 cursor-pointer">AWS Security</span>
      </div>
      <a href="https://github.com/abdisamadjoe/aws-login-alerts" target="_blank"
         class="inline-flex items-center gap-2 px-4 py-2 bg-mint text-black font-semibold rounded-full transition-colors duration-200 hover:bg-white hover:text-black focus:outline-none">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
